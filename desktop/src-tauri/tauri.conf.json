{
  "$schema": "https://raw.githubusercontent.com/tauri-apps/tauri/dev/crates/tauri-config-schema/schema.json",
  "productName": "Worktale",
  "version": "1.5.0",
  "identifier": "dev.worktale.desktop",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "Worktale",
        "width": 1280,
        "height": 860,
        "minWidth": 960,
        "minHeight": 640,
        "center": true,
        "transparent": true,
        "decorations": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "plugins": {},
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "icon": ["icons/icon.png", "icons/icon.ico"],
    "category": "DeveloperTool",
    "publisher": "Plural Software",
    "copyright": "Copyright © 2026 Plural Software",
    "shortDescription": "Developer work journal — turn your git history into a record of what you actually built",
    "longDescription": "Worktale Desktop is a native client for the Worktale developer work journal. It reads the same local SQLite database as the Worktale CLI, giving you a visual view of your commits, streaks, AI session tracking, and daily digests.",
    "windows": {
      "nsis": {
        "installMode": "currentUser",
        "languages": ["English"],
        "displayLanguageSelector": false
      }
    }
  }
}
